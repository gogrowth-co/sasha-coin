# Files and directories that stay LOCAL ONLY — never sync to VPS.
# rsync's --exclude-from reads these patterns. One per line.

# git
.git/
.gitignore

# local env (real secrets live in VPS .env)
.env
.env.local

# Marketing brain layer (Claude Code authoring environment)
CLAUDE.md
_context/
_sop/
_templates/
campaigns/
ads/
docs/
pages/
reports/
research/
seo/
videos/
social/

# Local task board UI + onboarding
.claude/
tasks.html
task-server.js
reports.html
onboarding.html
onboarding.md
onboarding-server.js

# Plan / spec scratch
docs/superpowers/

# Deploy infrastructure itself
deploy.sh
.deployignore

# OS / IDE
.DS_Store
.idea/
.vscode/
node_modules/
venv/
venv_buffer/

# Clawlett private state (must stay VPS-only)
Clawlett/config/
Clawlett/clawlett/scripts/config/

# Runtime state (VPS-only after initial bootstrap — monitor writes back here continuously)
# Bootstrap: SSH-copy state/lp-positions.json to VPS manually after first deploy.
# Never let rsync overwrite VPS state with stale local copy.
state/

# Mantle hackathon — dynamic generated signal file (regenerated on VPS each run)
content/mantle-signal.json
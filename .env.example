# Sasha Coin — env vars reference
# Copy to .env and fill in real values.
# Real .env is gitignored — never commit secrets.
#
# Source of truth for VPS runtime: /docker/openclaw-h3mk/data/.openclaw/.env
# Source of truth for universal keys: ~/Documents/Gabriel Mangabeira/marketing/.env

# ============================================================
# Universal keys (synced from marketing/.env)
# ============================================================
APIFY_TOKEN=<your-apify-token>
GEMINI_API_KEY=<your-gemini-api-key>
HASDATA_API_KEY=<your-hasdata-api-key>

# Google Workspace — direct OAuth (google-workspace skill)
# Setup: python3 .claude/skills/google-workspace/scripts/get-token.py
# Add this project's email as a test user in GCP Console (project: "Claude Code MangaOS") first.
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REFRESH_TOKEN=<run-get-token.py-to-generate>

# ============================================================
# Sasha Coin — project-specific keys
# ============================================================

# Twitter (X) API — used by scripts/tweet.js for direct posts and replies.
# Keys belong to the @SashaCoin_AI X developer app.
# Live values are on VPS h3mk. Copy from there or from 1Password.
X_API_KEY=<sasha-x-app-consumer-key>
X_API_SECRET=<sasha-x-app-consumer-secret>
X_ACCESS_TOKEN=<sasha-x-account-access-token>
X_ACCESS_SECRET=<sasha-x-account-access-secret>

# Buffer — autoscheduled posts for Sasha Coin X account.
# Use scoped names to avoid collision with other Buffer accounts.
BUFFER_ACCESS_TOKEN_SASHA_COIN=<sasha-buffer-access-token>
BUFFER_ORGANIZATION_ID_SASHA_COIN=<sasha-buffer-org-id>
BUFFER_CHANNEL_ID_SASHA_COIN_X=<sasha-buffer-x-channel-id>
# Legacy generic names — kept for backward compat with older scripts on VPS.
# New scripts must use the scoped names above.
BUFFER_ACCESS_TOKEN=<same-as-BUFFER_ACCESS_TOKEN_SASHA_COIN>
BUFFER_CHANNEL_ID=<same-as-BUFFER_CHANNEL_ID_SASHA_COIN_X>
BUFFER_ORGANIZATION_ID=<same-as-BUFFER_ORGANIZATION_ID_SASHA_COIN>

# GitHub — Sasha Coin repo token and repo path.
# Separate from the universal GITHUB_API_KEY used for dev activity tracking.
GITHUB_TOKEN=<sasha-github-personal-access-token>
GITHUB_REPO=gogrowth-co/sasha-coin

# Google API key — used by VPS gemini-image-* scripts.
# On VPS this is named GOOGLE_API_KEY. Same service as GEMINI_API_KEY.
# Recommendation: migrate VPS scripts to use GEMINI_API_KEY and retire this name.
GOOGLE_API_KEY=<same-as-GEMINI_API_KEY>

# Task board port — only needed when running task-server.js locally.
# TASK_SERVER_PORT=3005
# VPS connection — only needed for local ops scripts.
# SASHA_VPS_HOST=root@187.77.42.134
# SASHA_VPS_KEY=~/.ssh/hostinger_vps

# ============================================================
# Mantle Turing Test Hackathon 2026
# ============================================================
# Mantle RPC — used for ERC-8004 agent identity registration + on-chain data reads.
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz

# Mantle agent EOA — used by erc8004-register.js and erc8004-write.js.
# This is a dedicated Mantle EOA (separate from the Byreal Solana wallet).
# Fund with ~0.05 MNT for gas: https://bridge.mantle.xyz
# Generate a fresh EOA: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log(w.privateKey, w.address)"
# NEVER commit this key — set it directly in the VPS .env file.
MANTLE_AGENT_PK=<mantle-eoa-private-key-0x...>

# Byreal / Solana — used by byreal-cli for DeFi execution on Byreal CLMM DEX.
# Agent Solana keypair stored at: ~/.config/byreal/keys/id.json (set via byreal-cli wallet set)
# Configure on VPS: byreal-cli wallet set --private-key <base58-solana-key>
# BYREAL_SOLANA_WALLET=<base58-private-key>  # Never commit — configure directly via byreal-cli

# OpenRouter — used by mantle-signal.js for LLM bias extraction from X posts.
# If not set, falls back to rule-based extraction.
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Allora Network — decentralized inference API (Judge #1 integration)
# Free tier at: https://developer.allora.network
# Used by scripts/signals/allora.js for SOL/USD price predictions.
# If not set, Allora signal defaults to neutral (non-blocking).
ALLORA_API_KEY=<get-from-developer.allora.network>

# Elfa AI — smart mentions / social alpha (Judge #2 integration)
# Free tier at: https://elfa.ai
# Used by scripts/signals/elfa.js for smart-account mention tracking.
# If not set, Elfa signal defaults to neutral (non-blocking).
ELFA_API_KEY=<get-from-elfa.ai>

# Polymarket — no API key required (public Gamma API, no auth)
# Used by scripts/signals/polymarket.js for prediction market signals.
# No configuration needed — works out of the box.

# mETH Treasury — auto-compound threshold
# When MNT balance on Mantle exceeds this amount (in wei), auto-compound into mETH.
# Default: 0.01 MNT (10000000000000000 wei). Increase on mainnet.
MANTLE_COMPOUND_THRESHOLD_WEI=10000000000000000

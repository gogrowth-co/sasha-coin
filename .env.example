# Sasha Coin runtime env vars.
# Copy to .env on the VPS at /docker/openclaw-h3mk/data/.openclaw/.env
# .env itself is gitignored — never commit real secrets.

# Twitter (X) API — used by scripts/tweet.js for replies and direct posts
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Buffer — used by post_to_buffer.js for autoscheduled posts
# Get the token from https://account.buffer.com/account/apps/access-token
BUFFER_ACCESS_TOKEN=
BUFFER_CHANNEL_ID=
BUFFER_ORGANIZATION_ID=

# Apify — used by twitter-reply-gal for tweet scraping
APIFY_TOKEN=

# Google (Gemini) — used by gemini-image-* and other Google AI calls
GOOGLE_API_KEY=

# Local task board — only needed when running task-server.js locally
# TASK_SERVER_PORT=3001
# SASHA_VPS_HOST=root@187.77.42.134
# SASHA_VPS_KEY=~/.ssh/hostinger_vps